{# Base layout. Dark-first financial-terminal aesthetic with Eastern restraint. #}
<!DOCTYPE html>
<html lang="zh-Hans" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#0c0d10" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#f4efe6" media="(prefers-color-scheme: light)">
<title>{% block title %}散户叙事观测 · Tape{% endblock %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  /* ============================================================
     Tape · 散户叙事观测
     Dark-first financial terminal × 东方留白
     ============================================================ */

  :root[data-theme="dark"] {
    --bg:        #0c0d10;
    --bg-elev:   #15171c;
    --bg-card:   #131519;
    --ink:       #f0ebe1;
    --ink-soft:  #b8b0a2;
    --ink-mute:  #6b6558;
    --ink-dim:   #3a3833;
    --rule:      #23252b;
    --rule-soft: #1a1c21;
    --hot:       #e64d3a;   /* 朱砂 — heat */
    --hot-glow:  rgba(230,77,58,0.18);
    --cool:      #5b8db8;   /* 石青 — data */
    --warn:      #d9a64a;   /* 雌黄 — warning/mid */
    --up:        #e64d3a;   /* 中文涨红 */
    --down:      #4ea884;   /* 中文跌绿 */
  }
  :root[data-theme="light"] {
    --bg:        #f6f1e6;
    --bg-elev:   #ede5d2;
    --bg-card:   #fbf6ea;
    --ink:       #1a140d;
    --ink-soft:  #403629;
    --ink-mute:  #857968;
    --ink-dim:   #c8bfab;
    --rule:      #d4c9b3;
    --rule-soft: #e3dac4;
    --hot:       #c4382a;
    --hot-glow:  rgba(196,56,42,0.12);
    --cool:      #356588;
    --warn:      #a07725;
    --up:        #c4382a;
    --down:      #2f7a5c;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; text-rendering: optimizeLegibility; -webkit-font-smoothing: antialiased; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: "Inter", "Noto Serif SC", system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    font-weight: 400;
  }
  ::selection { background: var(--hot); color: #fff; }

  /* numeric-feeling mono */
  .mono { font-family: "JetBrains Mono", ui-monospace, monospace; font-feature-settings: "tnum"; }
  .serif { font-family: "Noto Serif SC", "Songti SC", serif; }

  /* ============================================================
     LAYOUT
     ============================================================ */
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  .shell { width: 100%; max-width: 1280px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 720px) { .shell { padding: 0 18px; } }

  /* ============================================================
     MASTHEAD — terminal-like, single line
     ============================================================ */
  .masthead {
    border-bottom: 1px solid var(--rule);
    padding: 18px 0;
    display: flex; align-items: center; gap: 24px;
  }
  .brand {
    display: flex; align-items: baseline; gap: 10px;
    text-decoration: none; color: var(--ink);
  }
  .brand .mark {
    width: 22px; height: 22px;
    background: var(--hot);
    border-radius: 2px;
    display: inline-block;
    transform: translateY(4px);
    box-shadow: 0 0 0 4px var(--hot-glow);
  }
  .brand .name-cn {
    font-family: "Noto Serif SC", serif;
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.04em;
  }
  .brand .tagline {
    font-family: "Noto Serif SC", serif;
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--ink-mute);
    border-left: 1px solid var(--rule);
    padding-left: 10px;
  }
  .topnav { margin-left: auto; display: flex; gap: 6px; align-items: center; }
  .topnav a, .topnav button {
    background: none; border: 1px solid transparent;
    color: var(--ink-soft);
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 6px 10px; cursor: pointer;
    text-decoration: none;
    transition: color .15s, border-color .15s, background .15s;
  }
  .topnav a:hover, .topnav button:hover { color: var(--hot); }
  .topnav .theme-toggle {
    border: 1px solid var(--rule);
    width: 32px; height: 32px; padding: 0;
    border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .topnav .theme-toggle:hover { border-color: var(--hot); }

  @media (max-width: 720px) {
    .masthead { gap: 12px; }
    .brand .tagline { display: none; }
    .topnav a:not(.theme-toggle) { display: none; }
  }

  /* ============================================================
     COLOPHON / FOOTER
     ============================================================ */
  .colophon {
    margin-top: 96px;
    padding: 24px 0 36px;
    border-top: 1px solid var(--rule);
    color: var(--ink-mute);
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.06em;
  }
  .colophon .row { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 16px; align-items: baseline; }
  .colophon .src { color: var(--ink-mute); }
  .colophon .disclaimer { font-style: italic; }

  {% block extra_css %}{% endblock %}
</style>
</head>
<body>
<div class="page">
  <header class="shell masthead">
    <a class="brand" href="./index.html">
      <span class="mark"></span>
      <span class="name-cn">叙事观测</span>
      <span class="tagline">散户题材热度榜</span>
    </a>
    <nav class="topnav">
      <a href="./index.html">归档</a>
      <a href="./feed.xml">RSS</a>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="切换主题">◐</button>
    </nav>
  </header>

  <main class="shell" style="flex:1;">
    {% block main %}{% endblock %}
  </main>

  <footer class="shell colophon">
    <div class="row">
      <div class="disclaimer">自动生成 · 仅供观测 · 非投资建议</div>
      <div class="src">x_search · reddit · ptt · krx · naver</div>
    </div>
  </footer>
</div>

<script>
(function() {
  var KEY = 'no.theme';
  var html = document.documentElement;
  var btn = document.getElementById('themeToggle');
  var saved = localStorage.getItem(KEY);
  if (saved === 'light' || saved === 'dark') html.setAttribute('data-theme', saved);
  btn && btn.addEventListener('click', function() {
    var cur = html.getAttribute('data-theme') || 'light';
    var next = cur === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', next);
    localStorage.setItem(KEY, next);
  });
})();
</script>
</body>
</html>
