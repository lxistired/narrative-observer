{% extends "_base.html.j2" %}
{% block title %}归档 · 散户叙事观测{% endblock %}

{% block extra_css %}
  .archive-cover {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--rule);
  }
  .archive-cover .meta-row {
    display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 24px;
  }
  .archive-cover .meta-row .vol { color: var(--hot); font-weight: 600; }
  .archive-cover h1 {
    font-family: "Noto Serif SC", serif;
    font-weight: 900;
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
  }
  .archive-cover h1 .accent { color: var(--hot); font-style: italic; font-weight: 700; }
  .archive-cover h1 .quiet { color: var(--ink-mute); font-weight: 400; }
  .archive-cover .deck {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 640px;
    margin: 0;
  }

  .latest {
    margin: 56px 0 0;
    padding: 36px 28px;
    background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--hot);
    border-radius: 4px;
    text-decoration: none; color: inherit;
    display: block;
    position: relative;
    transition: border-color .2s, transform .2s;
  }
  .latest:hover { border-color: var(--hot); transform: translateY(-2px); }
  .latest .tag-row {
    display: flex; gap: 12px; align-items: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 14px;
  }
  .latest .tag-row .live { color: var(--hot); font-weight: 600; }
  .latest .tag-row .live::before {
    content: ""; display: inline-block;
    width: 6px; height: 6px; background: var(--hot); border-radius: 50%;
    margin-right: 6px; vertical-align: 1px;
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 var(--hot-glow); }
    70%  { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  .latest h2 {
    font-family: "Noto Serif SC", serif;
    font-weight: 700;
    font-size: clamp(26px, 3.5vw, 38px);
    line-height: 1.2;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .latest:hover h2 { color: var(--hot); }
  .latest .meta {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; color: var(--ink-mute);
    letter-spacing: 0.06em;
  }

  .issues-label {
    margin: 56px 0 12px;
    display: flex; align-items: center; gap: 12px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-mute);
  }
  .issues-label::after {
    content: ""; flex: 1; height: 1px; background: var(--rule);
  }

  .issues {
    list-style: none; padding: 0; margin: 0;
  }
  .issues li {
    border-bottom: 1px solid var(--rule-soft);
  }
  .issues li:last-child { border-bottom: none; }
  .issues a {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 20px;
    align-items: baseline;
    padding: 18px 8px;
    text-decoration: none;
    color: var(--ink);
    transition: background .15s, padding .15s;
  }
  .issues a:hover { background: var(--bg-elev); padding-left: 16px; }
  .issues .num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; letter-spacing: 0.06em;
    color: var(--ink-mute);
  }
  .issues a:hover .num { color: var(--hot); }
  .issues .title {
    font-family: "Noto Serif SC", serif;
    font-weight: 500;
    font-size: 18px; line-height: 1.35;
    color: var(--ink);
  }
  .issues .ts {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; letter-spacing: 0.04em;
    color: var(--ink-mute);
  }
  @media (max-width: 600px) {
    .issues a { grid-template-columns: 48px 1fr; gap: 12px; padding: 14px 4px; }
    .issues .ts { grid-column: 2; padding-top: 4px; font-size: 10px; }
  }

  .empty {
    margin: 80px 0; padding: 48px 0;
    border-top: 1px dashed var(--rule);
    border-bottom: 1px dashed var(--rule);
    text-align: center;
    color: var(--ink-mute);
    font-style: italic;
    font-family: "Noto Serif SC", serif;
    font-size: 17px;
  }
{% endblock %}

{% block main %}
<section class="archive-cover">
  <div class="meta-row">
    <span class="vol">THE ARCHIVE</span>
    <span>{{ reports|length }} issue{% if reports|length != 1 %}s{% endif %}</span>
    <span>三市场观测</span>
  </div>
  <h1>每一天，<br>散户都<span class="accent">在说话。</span></h1>
  <p class="deck">来自 X、Reddit、PTT、KRX 与 Naver 的散户讨论与资金线索，按市场题材整理，按节奏更新。</p>
</section>

{% if reports %}
  {% set latest = reports[0] %}
  <a class="latest" href="./{{ latest.filename }}">
    <div class="tag-row">
      <span class="live">最新一期</span>
      <span>VOL · NO.{{ latest.number }}</span>
    </div>
    <h2>{{ latest.title_full }}</h2>
    <div class="meta">{{ latest.timestamp }}</div>
  </a>

  {% if reports|length > 1 %}
  <div class="issues-label">往期 · past issues</div>
  <ul class="issues">
    {% for r in reports[1:] %}
    <li>
      <a href="./{{ r.filename }}">
        <span class="num">No.{{ r.number }}</span>
        <span class="title">{{ r.title_full }}</span>
        <span class="ts">{{ r.timestamp }}</span>
      </a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
{% else %}
  <div class="empty">尚无观测期次 — 等待下一次扫描。</div>
{% endif %}
{% endblock %}
