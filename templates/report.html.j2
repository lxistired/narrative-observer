{% extends "_base.html.j2" %}
{% block title %}{{ title }} · 叙事观测{% endblock %}

{% block extra_css %}
  /* ============================================================
     COVER — 大字号 + 一行高密度元数据
     ============================================================ */
  .cover {
    padding: 56px 0 40px;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .cover .meta-row {
    display: flex; gap: 18px; align-items: center; flex-wrap: wrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 28px;
  }
  .cover .meta-row .vol { color: var(--hot); font-weight: 600; }
  .cover .meta-row .pulse {
    display: inline-block; width: 7px; height: 7px;
    background: var(--hot); border-radius: 50%;
    box-shadow: 0 0 0 0 var(--hot);
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 var(--hot-glow); }
    70%  { box-shadow: 0 0 0 10px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  .cover h1 {
    font-family: "Noto Serif SC", serif;
    font-weight: 900;
    font-size: clamp(44px, 7.5vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    color: var(--ink);
  }
  .cover h1 .accent {
    color: var(--hot);
    font-style: italic;
    font-weight: 700;
  }
  .cover h1 .quiet {
    color: var(--ink-mute);
    font-weight: 400;
  }
  .cover .deck {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 640px;
    margin: 0;
  }

  /* ============================================================
     TOP HEAT STRIP — Today's hottest themes across all markets
     A horizontal scrolling list of top 5 themes, eye-catching
     ============================================================ */
  .heat-strip {
    margin: 36px 0 8px;
    padding: 22px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .heat-strip-label {
    display: flex; align-items: center; gap: 10px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 16px;
  }
  .heat-strip-label::after {
    content: ""; flex: 1; height: 1px;
    background: linear-gradient(to right, var(--rule), transparent);
  }
  .heat-strip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    background: var(--rule);
  }
  .heat-tile {
    background: var(--bg);
    padding: 16px 18px 18px;
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; gap: 8px;
    position: relative;
    transition: background .15s;
    overflow: hidden;
  }
  .heat-tile::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--hot);
    transform: scaleY(var(--hot-pct, 1));
    transform-origin: bottom;
  }
  .heat-tile:hover { background: var(--bg-elev); }
  .heat-tile .rank {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px; letter-spacing: 0.12em;
    color: var(--ink-mute);
  }
  .heat-tile .rank .market { color: var(--hot); margin-right: 6px; font-weight: 600; }
  .heat-tile .name {
    font-family: "Noto Serif SC", serif;
    font-weight: 700;
    font-size: 17px; line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .heat-tile .ticks {
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
    margin-top: auto;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ============================================================
     MARKET LAYOUT — sticky left rail + content
     ============================================================ */
  .markets-wrap {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 56px;
    margin-top: 56px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .markets-wrap { grid-template-columns: 1fr; gap: 0; }
  }

  .rail {
    position: sticky; top: 24px;
    display: flex; flex-direction: column; gap: 4px;
  }
  @media (max-width: 900px) {
    .rail {
      position: sticky; top: 0; z-index: 50;
      flex-direction: row; gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--rule);
      margin: 24px -18px 0;
      padding: 0 18px;
      overflow-x: auto;
    }
  }
  .rail-item {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule-soft);
    text-decoration: none; color: var(--ink-soft);
    transition: color .15s;
  }
  .rail-item:hover { color: var(--ink); }
  .rail-item.active { color: var(--hot); }
  .rail-item.active .rail-num { color: var(--hot); }
  .rail-item .rail-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px; color: var(--ink-mute);
    letter-spacing: 0.08em;
  }
  .rail-item .rail-cn {
    font-family: "Noto Serif SC", serif;
    font-weight: 700; font-size: 18px;
    letter-spacing: 0.02em;
  }
  .rail-item .rail-en {
    font-family: "JetBrains Mono", monospace;
    font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-mute);
    grid-column: 2;
    margin-top: -2px;
  }
  .rail-item .rail-count {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px; color: var(--ink-mute);
    grid-row: 1;
  }
  @media (max-width: 900px) {
    .rail-item {
      grid-template-columns: auto auto;
      gap: 6px 10px;
      padding: 14px 18px;
      border-bottom: none;
      border-right: 1px solid var(--rule-soft);
      white-space: nowrap;
    }
    .rail-item .rail-en, .rail-item .rail-num { display: none; }
    .rail-item.active { border-bottom: 2px solid var(--hot); }
  }

  /* ============================================================
     MARKET SECTION
     ============================================================ */
  .market {
    padding-bottom: 64px;
    scroll-margin-top: 24px;
  }
  .market-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: end;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 16px;
    margin-bottom: 28px;
  }
  .market-head h2 {
    margin: 0;
    font-family: "Noto Serif SC", serif;
    font-weight: 900;
    font-size: 36px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .market-head h2 .en {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    display: block;
    margin-bottom: 6px;
  }
  .market-head .stat-strip {
    display: flex; gap: 20px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px; color: var(--ink-mute);
    letter-spacing: 0.04em;
    text-align: right;
  }
  .market-head .stat-strip .stat {
    display: flex; flex-direction: column; gap: 2px;
  }
  .market-head .stat-strip .stat .v { color: var(--ink); font-weight: 600; font-size: 13px; }
  @media (max-width: 720px) {
    .market-head h2 { font-size: 28px; }
    .market-head .stat-strip { font-size: 9.5px; gap: 12px; }
  }

  /* ============================================================
     THEME CARD — 主角
     ============================================================ */
  .themes { display: grid; grid-template-columns: 1fr; gap: 0; }
  .theme {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 0 20px;
    padding: 24px 0 28px;
    border-bottom: 1px solid var(--rule-soft);
    position: relative;
  }
  .theme:last-child { border-bottom: none; }

  .theme .num-block {
    display: flex; flex-direction: column; gap: 8px;
    padding-top: 4px;
  }
  .theme .num {
    font-family: "JetBrains Mono", monospace;
    font-size: 22px;
    font-weight: 600;
    color: var(--ink-mute);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .theme.cross .num { color: var(--hot); }

  /* heat bar — vertical gauge */
  .heat-gauge {
    width: 4px;
    height: 56px;
    background: var(--rule-soft);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
    margin-top: 4px;
  }
  .heat-gauge::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0;
    background: var(--gauge-color, var(--ink-mute));
    height: var(--gauge-h, 30%);
  }
  .theme[data-heat="high"] .heat-gauge { --gauge-color: var(--hot); --gauge-h: 100%; }
  .theme[data-heat="mid"]  .heat-gauge { --gauge-color: var(--warn); --gauge-h: 60%; }
  .theme[data-heat="low"]  .heat-gauge { --gauge-color: var(--ink-mute); --gauge-h: 28%; }

  .theme-body { min-width: 0; }

  .theme-head {
    display: flex; align-items: baseline; flex-wrap: wrap;
    gap: 10px 14px;
    margin-bottom: 14px;
  }
  .theme-name {
    margin: 0;
    font-family: "Noto Serif SC", serif;
    font-weight: 700;
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--ink);
  }
  .theme-name .native {
    display: inline;
    font-family: "JetBrains Mono", monospace;
    font-weight: 400;
    font-size: 12px;
    color: var(--ink-mute);
    margin-left: 8px;
    letter-spacing: 0.06em;
    vertical-align: 2px;
  }
  @media (max-width: 720px) {
    .theme { grid-template-columns: 40px 1fr; gap: 0 14px; }
    .theme-name { font-size: 21px; }
  }

  .badges {
    display: inline-flex; gap: 6px; align-items: center;
    margin-left: auto;
  }
  .heat-tag {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    font-weight: 600;
  }
  .heat-tag.high { color: var(--hot); background: var(--hot-glow); }
  .heat-tag.mid  { color: var(--warn); background: rgba(217,166,74,0.10); }
  .heat-tag.low  { color: var(--ink-mute); background: var(--bg-elev); }
  .heat-tag::before {
    content: ""; width: 5px; height: 5px;
    background: currentColor; border-radius: 50%;
  }
  .cross-tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--hot);
    color: var(--hot);
    border-radius: 2px;
    font-weight: 600;
  }

  /* time-window badges — 24h / 7d hot indicators + tempo */
  .win-tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 2px;
    font-weight: 600;
    border: 1px solid currentColor;
    background: transparent;
  }
  .win-tag .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: currentColor;
  }
  .win-tag.win-24h { color: var(--hot); }
  .win-tag.win-7d  { color: var(--cool); }
  .win-tag.off { opacity: 0.32; }
  .win-tag.off .dot { background: transparent; border: 1px solid currentColor; }

  .tempo-tag {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: "Noto Serif SC", serif;
    font-weight: 700; font-size: 11.5px;
    letter-spacing: 0.06em;
    padding: 3px 9px;
    border-radius: 2px;
  }
  .tempo-tag.new          { color: var(--hot);  background: var(--hot-glow); }
  .tempo-tag.accelerating { color: #fff;        background: var(--hot); }
  .tempo-tag.sustained    { color: var(--cool); background: rgba(53,101,136,0.12); }
  .tempo-tag.fading       { color: var(--ink-mute); background: var(--bg-elev); }
  :root[data-theme="dark"] .tempo-tag.sustained { background: rgba(91,141,184,0.16); }
  .tempo-tag::before {
    content: ""; width: 6px; height: 6px;
    background: currentColor; border-radius: 50%;
  }
  .tempo-tag.accelerating::before { background: #fff; animation: pulse 1.6s infinite; }

  /* tickers — horizontal chips */
  .tickers {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 14px;
  }
  .tk {
    display: inline-flex; align-items: baseline; gap: 8px;
    padding: 5px 10px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 3px;
    line-height: 1.1;
  }
  .tk .code {
    font-family: "JetBrains Mono", monospace;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .tk .name {
    font-family: "Noto Serif SC", serif;
    font-size: 13px;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .tk .native {
    font-size: 11px;
    color: var(--ink-mute);
  }

  /* narrative — the headline hook */
  .narrative {
    font-family: "Noto Serif SC", serif;
    font-size: 17.5px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 14px;
    font-weight: 400;
    letter-spacing: -0.003em;
  }

  /* details — collapsible meta block */
  details.detail {
    margin-top: 6px;
    border-top: 1px dashed var(--rule-soft);
    padding-top: 10px;
  }
  details.detail summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mute);
    user-select: none;
  }
  details.detail summary::-webkit-details-marker { display: none; }
  details.detail summary::before {
    content: "+";
    width: 14px; height: 14px;
    border: 1px solid var(--ink-mute);
    border-radius: 2px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 11px;
    line-height: 1;
    transition: transform .15s;
  }
  details.detail[open] summary::before { content: "−"; }
  details.detail summary:hover { color: var(--ink); }
  details.detail summary:hover::before { border-color: var(--ink); }

  .detail-grid {
    margin-top: 14px;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 10px 16px;
  }
  .detail-grid dt {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    padding-top: 3px;
  }
  .detail-grid dd {
    margin: 0;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .detail-grid dd ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 6px;
  }
  .detail-grid dd ul li {
    padding-left: 14px;
    position: relative;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .detail-grid dd ul li::before {
    content: ""; position: absolute; left: 0; top: 9px;
    width: 6px; height: 1px; background: var(--ink-mute);
  }
  .src-pill {
    display: inline-flex;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px; letter-spacing: 0.06em;
    color: var(--ink-soft);
    padding: 2px 7px;
    background: var(--bg-elev);
    border-radius: 2px;
    margin-right: 4px;
  }
  @media (max-width: 720px) {
    .detail-grid { grid-template-columns: 1fr; gap: 4px; }
    .detail-grid dt { padding-top: 0; }
  }

  /* fallback */
  .raw-fallback {
    margin: 16px 0; padding: 16px;
    border: 1px dashed var(--rule);
    border-radius: 3px;
    background: var(--bg-card);
    font-family: "JetBrains Mono", monospace;
    font-size: 12.5px;
    color: var(--ink-soft);
    white-space: pre-wrap;
  }
{% endblock %}

{% block main %}
<article class="cover">
  <div class="meta-row">
    <span class="pulse"></span>
    <span class="vol">VOL.{{ issue.year }} · NO.{{ issue.number }}</span>
    <span>{{ issue.date_long }}</span>
    <span style="margin-left:auto; color: var(--ink-soft);">三市场观测 · {{ markets|length }} markets</span>
  </div>
  <h1>今日，散户在<br><span class="accent">押注什么。</span></h1>
  <p class="deck">{{ issue.deck }}</p>
</article>

{% if heat_top %}
<section class="heat-strip">
  <div class="heat-strip-label">今日最热</div>
  <div class="heat-strip-grid">
    {% for h in heat_top %}
    <a class="heat-tile" href="#m-{{ h.market_code }}" style="--hot-pct:{{ h.pct }}">
      <span class="rank"><span class="market">{{ h.market_label }}</span>· {{ "%02d"|format(loop.index) }}</span>
      <span class="name">{{ h.name }}</span>
      <span class="ticks">{{ h.ticks }}</span>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

<div class="markets-wrap">
  <aside class="rail">
    {% for m in markets %}
    <a class="rail-item" href="#m-{{ m.code }}" data-market="{{ m.code }}">
      <span class="rail-num">M.{{ "%02d"|format(loop.index) }}</span>
      <span class="rail-cn">{{ m.label_cn }}</span>
      <span class="rail-count mono">{{ m.themes|length }}</span>
      <span class="rail-en">{{ m.label_en }}</span>
    </a>
    {% endfor %}
  </aside>

  <div class="markets-content">
    {% for m in markets %}
    <section class="market" id="m-{{ m.code }}">
      <header class="market-head">
        <h2>
          <span class="en">M.{{ "%02d"|format(loop.index) }} · {{ m.label_en }}</span>
          {{ m.label_cn }}
        </h2>
        <div class="stat-strip">
          <div class="stat"><span class="v mono">{{ m.themes|length }}</span><span>题材</span></div>
          {% if m.stat_cross is defined %}<div class="stat"><span class="v mono">{{ m.stat_cross }}</span><span>跨源</span></div>{% endif %}
          {% if m.stat_tickers is defined %}<div class="stat"><span class="v mono">{{ m.stat_tickers }}</span><span>标的</span></div>{% endif %}
        </div>
      </header>

      {% if m.themes %}
      <div class="themes">
        {% for t in m.themes %}
        <article class="theme {% if t.cross_source %}cross{% endif %}" data-heat="{{ t.heat or 'low' }}">
          <div class="num-block">
            <span class="num">{{ "%02d"|format(loop.index) }}</span>
            <div class="heat-gauge"></div>
          </div>
          <div class="theme-body">
            <header class="theme-head">
              <h3 class="theme-name">{{ t.name }}{% if t.name_native and t.name_native != t.name %}<span class="native">{{ t.name_native }}</span>{% endif %}</h3>
              <div class="badges">
                {% if t.tempo %}
                  <span class="tempo-tag {{ t.tempo }}">
                    {%- if t.tempo == 'new' -%}新冒头
                    {%- elif t.tempo == 'accelerating' -%}加速中
                    {%- elif t.tempo == 'sustained' -%}本周持续
                    {%- elif t.tempo == 'fading' -%}退潮
                    {%- else -%}{{ t.tempo }}{%- endif -%}
                  </span>
                {% endif %}
                <span class="win-tag win-24h {% if not t.hot_24h %}off{% endif %}" title="24h 窗口">
                  <span class="dot"></span>24H
                </span>
                <span class="win-tag win-7d {% if not t.hot_7d %}off{% endif %}" title="7d 窗口">
                  <span class="dot"></span>7D
                </span>
                {% if t.cross_source %}<span class="cross-tag">跨源</span>{% endif %}
                {% if t.heat %}<span class="heat-tag {{ t.heat }}">{{ t.heat }}</span>{% endif %}
              </div>
            </header>

            {% if t.tickers %}
            <div class="tickers">
              {% for tk in t.tickers %}
              <span class="tk">
                <span class="code">{{ tk.code }}</span>
                {% if tk.name_cn %}<span class="name">{{ tk.name_cn }}</span>{% endif %}
                {% if tk.name_native and tk.name_native != tk.name_cn %}<span class="native">{{ tk.name_native }}</span>{% endif %}
              </span>
              {% endfor %}
            </div>
            {% endif %}

            {% if t.narrative %}<p class="narrative">{{ t.narrative }}</p>{% endif %}

            {% if t.evidence or t.sources %}
            <details class="detail">
              <summary>展开证据 · evidence</summary>
              <dl class="detail-grid">
                {% if t.evidence %}
                <dt>线索</dt>
                <dd><ul>{% for e in t.evidence %}<li>{{ e }}</li>{% endfor %}</ul></dd>
                {% endif %}
                {% if t.sources %}
                <dt>数据源</dt>
                <dd>{% for s in t.sources %}<span class="src-pill">{{ s }}</span>{% endfor %}</dd>
                {% endif %}
              </dl>
            </details>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
      {% elif m.raw_text %}
      <div class="raw-fallback">{{ m.raw_text }}</div>
      {% else %}
      <p style="color: var(--ink-mute); font-style: italic;">本期此市场未拿到结构化数据。</p>
      {% endif %}
    </section>
    {% endfor %}
  </div>
</div>

<script>
(function() {
  // active rail item on scroll
  var rail = document.querySelectorAll('.rail-item');
  var sections = Array.from(rail).map(function(a) {
    var code = a.getAttribute('data-market');
    return code ? document.getElementById('m-' + code) : null;
  }).filter(Boolean);
  if (!sections.length) return;
  function activate() {
    var y = window.scrollY + 120;
    var idx = 0;
    for (var i = 0; i < sections.length; i++) {
      if (sections[i].offsetTop <= y) idx = i;
    }
    rail.forEach(function(t, i) { t.classList.toggle('active', i === idx); });
  }
  window.addEventListener('scroll', activate, {passive: true});
  activate();
})();
</script>
{% endblock %}
